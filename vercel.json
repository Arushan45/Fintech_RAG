{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "pip install -r requirements-vercel.txt",
  "functions": {
    "api/index.py": {
      "maxDuration": 60,
      "excludeFiles": "{.venv/**,__pycache__/**,.git/**,data/**,*.log,app.py,ingest.py,render.yaml,streamlit*.log,backend*.log}"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.py"
    }
  ]
}
